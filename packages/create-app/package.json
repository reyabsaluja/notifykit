{
  "name": "create-notifykit-app",
  "version": "0.0.1",
  "license": "MIT",
  "engines": { "node": ">=18" },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/reyabsaluja/notifykit",
    "directory": "packages/create-app"
  },
  "homepage": "https://github.com/reyabsaluja/notifykit",
  "bugs": "https://github.com/reyabsaluja/notifykit/issues",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "create-notifykit-app": "./dist/bin/create.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "template"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/bin/create.js', 0o755)\"",
    "prepublishOnly": "npm run build",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3"
  }
}
