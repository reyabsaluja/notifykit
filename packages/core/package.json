{
  "name": "@notifykitjs/core",
  "version": "0.0.1",
  "description": "App-native notifications for TypeScript.",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/reyabsaluja/notifykit",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/reyabsaluja/notifykit",
  "bugs": "https://github.com/reyabsaluja/notifykit/issues",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "import": "./dist/zod.js"
    },
    "./valibot": {
      "types": "./dist/valibot.d.ts",
      "import": "./dist/valibot.js"
    },
    "./arktype": {
      "types": "./dist/arktype.d.ts",
      "import": "./dist/arktype.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "bun test"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "zod": "^4.4.2",
    "valibot": "^1.0.0",
    "arktype": "^2.1.0"
  },
  "peerDependencies": {
    "zod": "^3.20.0 || ^4.0.0",
    "valibot": "^1.0.0",
    "arktype": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "valibot": {
      "optional": true
    },
    "arktype": {
      "optional": true
    }
  },
  "sideEffects": false
}
