{
  "name": "@notifykitjs/drizzle",
  "version": "0.0.1",
  "description": "Drizzle ORM persistence adapter for NotifyKit.",
  "keywords": ["notifications", "typescript", "drizzle", "postgresql", "sqlite"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reyabsaluja/notifykit.git",
    "directory": "packages/drizzle-adapter"
  },
  "homepage": "https://github.com/reyabsaluja/notifykit",
  "bugs": "https://github.com/reyabsaluja/notifykit/issues",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/sqlite": {
      "types": "./dist/schema/sqlite.d.ts",
      "import": "./dist/schema/sqlite.js"
    },
    "./schema/postgres": {
      "types": "./dist/schema/postgres.d.ts",
      "import": "./dist/schema/postgres.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "bun test"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.30.0",
    "@notifykitjs/core": "^0.0.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "drizzle-orm": "^0.45.2",
    "@notifykitjs/core": "^0.0.1",
    "typescript": "^5.6.3"
  },
  "sideEffects": false
}
